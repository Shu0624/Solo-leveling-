### Framer Motion Preset Library (copy-paste ready):

```javascript
// Page transition wrapper
const pageTransition = {
  initial: { opacity: 0, y: __ },
  animate: { opacity: 1, y: 0, transition: { duration: 0.__, ease: [0.__, 0.__, 0.__, 0.__] } },
  exit: { opacity: 0, y: -__, transition: { duration: 0.__ } }
};

// Card hover effect
const cardHover = {
  rest: { scale: 1, boxShadow: "0 0 0 rgba(0,0,0,0)" },
  hover: { scale: 1.0__, y: -__, boxShadow: "var(--accent-glow)", transition: { duration: 0.__, ease: "easeOut" } }
};

// Stagger children (for grids/lists)
const staggerContainer = {
  animate: { transition: { staggerChildren: 0.__ } }
};
const staggerItem = {
  initial: { opacity: 0, y: __ },
  animate: { opacity: 1, y: 0, transition: { duration: 0.__, ease: "easeOut" } }
};

// Number counter (for dashboard stats)
// Use framer-motion's useMotionValue + useTransform + animate

// Loading skeleton
const shimmer = {
  initial: { backgroundPosition: "-200% 0" },
  animate: { backgroundPosition: "200% 0", transition: { repeat: Infinity, duration: 1.5, ease: "linear" } }
};
```

