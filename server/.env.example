# =====================================================================
# LevelUp Server — Environment Configuration
# Copy this file to .env and fill in your values
# =====================================================================

# MongoDB connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT Secret — MUST be a cryptographically random string (64+ chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING

# Groq API Key — Get from https://console.groq.com
GROQ_API_KEY=gsk_your_api_key_here

# Client URL for CORS (comma-separated for multiple origins)
CLIENT_URL=http://localhost:5173

# Server port
PORT=5000
